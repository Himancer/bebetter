# Copy this file to `.env` and fill in the values.
# For a local SQLite run, nothing here is strictly required except GROQ_API_KEY
# (and only if you want the AI coach to actually respond).

# Groq API key for the AI coach chatbot.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# JWT signing secret. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional: PostgreSQL connection string (used in production; Render provides it).
# Leave this unset locally to use a local SQLite file (backend/bebetter.db).
# DATABASE_URL=postgresql://user:password@host:5432/bebetter
